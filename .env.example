# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env to version control

# Firebase
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── AI Chat backend (used by /api/chat) ────────────────────────────────
# Set ONE of the two below. Server-side only, NOT exposed to the browser.
# Configure in Vercel dashboard → Settings → Environment Variables.
#
# RECOMMENDED — direct Anthropic API. Works from any backend.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
#
# OR — AgentRouter. NOTE: AgentRouter blocks non-CLI clients,
# so this will return 401 "unauthorized client detected" from a website.
# Only useful if you're calling from Claude Code / Codex / Droid / etc.
# AGENTROUTER_API_KEY=sk-your-agentrouter-key-here
