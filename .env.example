# Copy this file to .env and fill in your credentials
# IMPORTANT: Never commit .env to version control

# Firebase
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── AI Chat backend (used by /api/chat) ────────────────────────────────
# Set in Vercel dashboard → Settings → Environment Variables.
#
# For AgentRouter (recommended):
#   Get your token at https://agentrouter.org/console/token
ANTHROPIC_BASE_URL=https://agentrouter.org
ANTHROPIC_API_KEY=sk-xxx
#
# For direct Anthropic API:
#   Get a key at https://console.anthropic.com/settings/keys
#   Remove ANTHROPIC_BASE_URL and set ANTHROPIC_API_KEY to your Anthropic key.
